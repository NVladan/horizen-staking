# ===========================================================================
# Horizen tstZEN Staking — environment template
#
#   cp .env.example .env   then fill in the blanks below.
#   The real .env is gitignored; NEVER commit secrets. This file is the only
#   env file that belongs in git.
# ===========================================================================

# ---------------------------------------------------------------------------
# Network — Horizen L3 mainnet (Caldera on Base). Testnet chain id: 845320009.
# RPC_URL and EXPLORER_URL must be http(s) URLs (validated at startup).
# ---------------------------------------------------------------------------
CHAIN_ID=26514
CHAIN_NAME=Horizen
RPC_URL=https://horizen.calderachain.xyz/http
EXPLORER_URL=https://horizen.calderaexplorer.xyz

# ---------------------------------------------------------------------------
# Deployer wallet — used ONLY by scripts/ (deploy, fund_rewards). The web app
# NEVER reads this. Needs a little ETH on Horizen L3 for gas (bridge from Base).
# Use a throwaway key; do not commit the real .env. Leave blank if you deploy
# via the browser /admin console instead of the CLI scripts.
# ---------------------------------------------------------------------------
DEPLOYER_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# Admin console (/admin) — Sign-In-With-Ethereum gated.
#   ADMIN_ADDRESS  the only wallet allowed to deploy/fund via the browser.
#   ADMIN_OPEN     if ADMIN_ADDRESS is blank, the console stays LOCKED unless
#                  this is 1 (fail-closed by default).
# ---------------------------------------------------------------------------
ADMIN_ADDRESS=
ADMIN_OPEN=0

# ---------------------------------------------------------------------------
# Contract addresses — filled in automatically by the deploy step
# (scripts/deploy.py or the /admin console). Leave blank before first deploy.
# ---------------------------------------------------------------------------
TSTZEN_ADDRESS=
STAKING_ADDRESS=

# ---------------------------------------------------------------------------
# Staking parameters — used only at deploy time (constructor args).
# ---------------------------------------------------------------------------
REWARD_PER_YEAR=50000        # tstZEN distributed per year across all stakers
EPOCH_DURATION_SECONDS=1800  # 30 minutes

# ---------------------------------------------------------------------------
# Flask
#   FLASK_SECRET_KEY signs the admin session cookie. With ADMIN_ADDRESS set the
#   app REFUSES to start on a blank/placeholder key. Generate a strong one:
#       python -c "import secrets; print(secrets.token_hex(32))"
#   Keep FLASK_DEBUG=0 anywhere reachable. Set SESSION_COOKIE_SECURE=1 on HTTPS.
# ---------------------------------------------------------------------------
FLASK_SECRET_KEY=
FLASK_DEBUG=0
SESSION_COOKIE_SECURE=0
